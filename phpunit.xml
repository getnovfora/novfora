<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_URL" value="http://localhost"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <!-- The test suite provisions its own database, so it must never be redirected to the installer
             or have its drivers hardened by the pre-install boot hook. Installer-specific tests opt back
             in by toggling this config + pointing the marker/.env at temp paths. -->
        <env name="NOVFORA_INSTALL_ENFORCE" value="false"/>
        <!-- Phase-1.5 F-A: the install setup token is off by default; the token tests opt in. -->
        <env name="NOVFORA_INSTALL_REQUIRE_TOKEN" value="false"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <!-- Anti-spam: frictionless by default in tests (no CAPTCHA, no live StopForumSpam network call);
             the dedicated anti-spam suites opt back in to the strict config per test. -->
        <env name="NOVFORA_CAPTCHA" value="none"/>
        <env name="NOVFORA_SFS_API" value="false"/>
        <!-- Phase-1.5 F-B strict registration controls are off by default in the suite (frictionless);
             the dedicated RegistrationHardeningTest opts each one back in. -->
        <env name="NOVFORA_REGISTER_THROTTLE" value="false"/>
        <env name="NOVFORA_HONEYPOT_REQUIRED" value="false"/>
        <env name="NOVFORA_QA_SINGLE_USE" value="false"/>
        <env name="NOVFORA_SFS_WARM" value="false"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SCOUT_DRIVER" value="database"/>
        <env name="FILESYSTEM_DISK" value="local"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
