# NovFora — repo baseline .gitignore (Cowork, 2026-06-02)
# Laravel/Node-specific ignores (vendor/, node_modules/, .env, public/build, etc.) are added
# by the Code session at M0 when the app is scaffolded. For now: OS / editor cruft only.

.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Spike 0 (throwaway scaffold) — keep the source files as a reference for M0; exclude heavy/generated artifacts.
novfora-spike/vendor/
novfora-spike/node_modules/
novfora-spike/public/build/
novfora-spike/public/spike-uploads/
novfora-spike/public/hot
novfora-spike/storage/framework/
novfora-spike/bootstrap/cache/
novfora-spike/database/*.sqlite
novfora-spike/.env
novfora-spike/test-results/
novfora-spike/playwright-report/

# Laravel / Node — repo-root app (M0). IMPORTANT: /public/build is intentionally NOT ignored;
# prebuilt assets are committed so the baseline shared host needs no Node runtime.
/vendor/
/node_modules/
/.env
/.env.backup
/.env.production
/.phpunit.cache
/.phpunit.result.cache
/public/hot
/public/storage
/storage/*.key
/storage/installed
/storage/install-token.txt
/storage/novfora-restore.json
/storage/novfora-restore.lock
/storage/hearth-restore.json
/storage/hearth-restore.lock
/storage/backups
/storage/dusk-install
/storage/pail
/bootstrap/ssr
/auth.json
npm-debug.log
yarn-error.log
/.nova
/.zed

# Deployable release bundle(s) — build artifact; never commit the binary (see docs/REAL-HOST-VALIDATION.md §2).
# /*.zip covers novfora-release.zip + any future root release archive (and the retired hearth-release.zip);
# replaces the prior duplicated /novfora-release.zip entries.
/*.zip

# Owner's local visual-feedback drops (round screenshots) + the scratch PR-body draft — local-only.
/1st_Visual_Feedback/
/.pr-body.md

# Local-only scratch — never push. Cowork session runtime artifacts and ad-hoc troubleshooting
# (screenshots, scratch notes). Exception: the committed project Claude Code config (settings.json,
# e.g. AI-attribution off) is kept so it travels with the repo across machines.
/.claude/*
!/.claude/settings.json
/troubleshoot/

# Local-only forum-seed import experiment — NOT shipped. The HTTP controller is an unauthenticated
# mass-write endpoint (no auth/admin guard, raw password hashes from input) and must never reach the
# repo; the Artisan command is a local dev seeder. Kept untracked + ignored on purpose.
/app/Http/Controllers/ImportForumSeedController.php
/app/Console/Commands/ImportForumSeedCommand.php
