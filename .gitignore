# NovFora — repo baseline .gitignore (Cowork, 2026-06-02)
# Laravel/Node-specific ignores (vendor/, node_modules/, .env, public/build, etc.) are added
# by the Code session at M0 when the app is scaffolded. For now: OS / editor cruft only.

.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Spike 0 (throwaway scaffold) — keep the source files as a reference for M0; exclude heavy/generated artifacts.
nevo-spike/vendor/
nevo-spike/node_modules/
nevo-spike/public/build/
nevo-spike/public/spike-uploads/
nevo-spike/public/hot
nevo-spike/storage/framework/
nevo-spike/bootstrap/cache/
nevo-spike/database/*.sqlite
nevo-spike/.env
nevo-spike/test-results/
nevo-spike/playwright-report/

# Laravel / Node — repo-root app (M0). IMPORTANT: /public/build is intentionally NOT ignored;
# prebuilt assets are committed so the baseline shared host needs no Node runtime.
/vendor/
/node_modules/
/.env
/.env.backup
/.env.production
/.phpunit.cache
/.phpunit.result.cache
/public/hot
/public/storage
/storage/*.key
/storage/installed
/storage/install-token.txt
/storage/novfora-restore.json
/storage/novfora-restore.lock
/storage/hearth-restore.json
/storage/hearth-restore.lock
/storage/backups
/storage/dusk-install
/storage/pail
/bootstrap/ssr
/auth.json
npm-debug.log
yarn-error.log
/.nova
/.zed

# Deployable release bundle — build artifact; never commit the binary (see docs/REAL-HOST-VALIDATION.md §2).
/novfora-release.zip
/nevo-release.zip
/hearth-release.zip

# Owner's local visual-feedback drops (round screenshots) + the scratch PR-body draft — local-only.
/1st_Visual_Feedback/
/.pr-body.md

# Local-only scratch — never push. Cowork session runtime artifacts and ad-hoc troubleshooting
# (screenshots, scratch notes). Exception: the committed project Claude Code config (settings.json,
# e.g. AI-attribution off) is kept so it travels with the repo across machines.
/.claude/*
!/.claude/settings.json
/troubleshoot/
