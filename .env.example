# ──────────────────────────────────────────────────────────────────────────────────────────────────
# Hearth — example environment. Copy to `.env` (the web installer and `composer setup` do this for you).
# BASELINE defaults are uncommented and need no extra services: PHP 8.3 + MySQL + cron. ENHANCED-tier
# options (Redis, Meilisearch, Reverb, S3) are shown commented — uncomment them to light up upgrades with
# NO code change (ADR-0003). Run on a shared host? You usually only edit the APP_* and DB_* blocks; the
# installer writes those for you.
# ──────────────────────────────────────────────────────────────────────────────────────────────────

# ── Application ─────────────────────────────────────────────────────────────────────────────────────
APP_NAME="Hearth"
# local for development; the installer writes `production` for a live site.
APP_ENV=local
# Leave blank. Set by the web installer, or run `php artisan key:generate`. Never commit a real key.
APP_KEY=
# true for development; the installer writes `false` for production (never expose stack traces publicly).
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# ── Password hashing (security by default) ──────────────────────────────────────────────────────────
# argon2id is the default. Hosts whose PHP lacks libargon2 may set HASH_DRIVER=bcrypt. Argon work
# factors follow OWASP guidance (~64 MB, t=4).
HASH_DRIVER=argon2id
ARGON_MEMORY=65536
ARGON_THREADS=1
ARGON_TIME=4
BCRYPT_ROUNDS=12

# ── Logging ─────────────────────────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ────────────────────────────────────────────────────────────────────────────────────────
# Baseline tier: MySQL 8 / MariaDB. PostgreSQL is supported on the enhanced (Docker/VPS) tier — set
# DB_CONNECTION=pgsql and DB_PORT=5432. SQLite (DB_CONNECTION=sqlite, DB_DATABASE=/abs/path.sqlite) works
# for tiny/single-admin installs.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hearth
DB_USERNAME=hearth
DB_PASSWORD=

# ── Cache · session · queue (baseline: database, drained by the cron line — ADR-0011) ───────────────
# The queue is the database queue, drained by `php artisan schedule:run` (the single cron line). No
# daemon required. Enhanced tier: switch all three to redis (see the Redis block below) for a real worker.
CACHE_STORE=database
# CACHE_PREFIX=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# HTTPS-only session cookie (security by default). The web installer sets this to true automatically when
# your site URL is https://. Set it true by hand if you serve over TLS and installed via the CLI. Leave
# unset/false only for a plain-http (non-TLS) site.
# SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=database

# ── Search (ADR-0010) ───────────────────────────────────────────────────────────────────────────────
# Baseline: the database (MySQL FULLTEXT/LIKE) via Laravel Scout. Enhanced: Meilisearch (see below).
SCOUT_DRIVER=database

# ── Mail (ADR-0014) ─────────────────────────────────────────────────────────────────────────────────
# Baseline: host SMTP (best-effort — see system-architecture §5). Enhanced: a transactional provider
# (ses/postmark/mailgun/resend) with SPF/DKIM/DMARC. Mail is queued and sent by the cron line.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Deliverability: digest + bounce/suppression (Spike P2, Phase-2 plan §4) ───────────────────────────
# REFERENCE PIPELINE, DORMANT BY DEFAULT. Off → the digest + bounce-poll cron ticks are no-ops, the webhook
# route is unregistered, and the live immediate notification path is untouched. P2-M2 turns this on. See
# docs/product/spike-p2-memo.md. RECOMMENDED for sending to strangers (verification/digests): a transactional
# provider (Postmark/SES/Mailgun) with an ON-DOMAIN From + aligned SPF/DKIM/DMARC — baseline SMTP is the
# zero-config floor, not a reputation-safe sender.
# HEARTH_DELIVERABILITY=true          # master switch for everything below
# HEARTH_DIGEST=true                  # cron-batched digest emails (idempotent per cadence period)
# HEARTH_DIGEST_USERS_PER_TICK=50     # per-tick send cap (volume hygiene; a backlog drains over ticks)
# HEARTH_DIGEST_ITEM_RATE=100         # max items per single digest (overflow rolls to the next period)
# Provider bounce/complaint webhook (HMAC over the raw body; the route registers only when both are set):
# HEARTH_MAIL_WEBHOOK=true
# HEARTH_MAIL_WEBHOOK_SECRET=         # a long random string, NOT your APP_KEY
# VERP signed Return-Path so a bounce identifies the recipient with no body parsing (forgery-safe):
# HEARTH_VERP=true
# HEARTH_VERP_DOMAIN=bounce.example.com
# HEARTH_VERP_KEY=                    # a long random HMAC key
# Cron-polled IMAP bounce mailbox (needs the php-imap extension; degrades to a no-op when absent):
# HEARTH_BOUNCE_IMAP=true
# HEARTH_BOUNCE_IMAP_HOST=imap.example.com
# HEARTH_BOUNCE_IMAP_USER=bounces@example.com
# HEARTH_BOUNCE_IMAP_PASS=
# HEARTH_BOUNCE_IMAP_MAILBOX=INBOX

# ── File storage ────────────────────────────────────────────────────────────────────────────────────
# Baseline: the local disk (needs `php artisan storage:link` — the installer does this). Avatars, covers,
# and attachment thumbnails need the GD or Imagick PHP extension. Enhanced: S3/MinIO (see the AWS block).
FILESYSTEM_DISK=local

# ── Real-time / broadcast ───────────────────────────────────────────────────────────────────────────
# Baseline: none — the notification bell uses Livewire polling. Enhanced (Phase 4): Reverb (see below).
BROADCAST_CONNECTION=log

# ── Anti-spam (ADR-0007) ────────────────────────────────────────────────────────────────────────────
# CAPTCHA provider for protected actions: qa (baseline, no external service) | turnstile | null.
HEARTH_CAPTCHA=qa
# Use the live StopForumSpam API (true) or only the cron-cached blocklist (false). Degrades gracefully
# either way — a slow/dead API never stalls or errors registration.
HEARTH_SFS_API=true
# Cloudflare Turnstile (only if HEARTH_CAPTCHA=turnstile; absent secret degrades to the qa challenge).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ── Theme (ADR-0009) ────────────────────────────────────────────────────────────────────────────────
# Blank = the built-in mobile-first default theme. Set to a child-theme slug under ./themes to override.
HEARTH_THEME=

# ── Backups (M5) ────────────────────────────────────────────────────────────────────────────────────
# Automated backups (DB + storage + manifest) run from the cron line. Cadence: daily | weekly | off.
HEARTH_BACKUP_SCHEDULE=daily
HEARTH_BACKUP_KEEP=7
# HEARTH_BACKUP_PATH=/absolute/path/outside/web/root
# How MySQL/MariaDB is dumped: auto (mysqldump when proc_open is allowed, else a pure-PHP dump over PDO) |
# php (force the pure-PHP path — use this if your host disables proc_open/exec) | shell (force mysqldump).
# Run `php artisan hearth:doctor` to see which your host will use.
# HEARTH_BACKUP_DB_METHOD=auto
# Restore (RH-11): the no-SSH "Restore" in Admin → System → Backups runs from the cron line behind a brief
# maintenance page. A pre-restore safety snapshot of the current state is taken first (set false to skip it).
# A restore is single-attempt and fail-safe: if it can't finish it holds the site in maintenance rather than
# serving a half-restored database — recover by restoring a known-good backup again.
# HEARTH_RESTORE_SAFETY_BACKUP=true

# ── Installer (M5) ──────────────────────────────────────────────────────────────────────────────────
# Advanced — leave the default. When true, an un-installed site forces the web installer; once installed
# the marker file (storage/installed) locks it. Set false only to disable the installer entirely.
# HEARTH_INSTALL_ENFORCE=true

# ── Automatic upgrade (RH-10 / ADR-0021) ────────────────────────────────────────────────────────────
# Keeps the promise true: extract a new release over a live install and the schema migrates itself via
# the cron line — no SSH. true (default) = the cron tick takes a backup then applies pending migrations
# behind a brief branded maintenance page (so new code can't 500 a signed-in page on a column that does
# not exist yet). false = MANUAL: nothing auto-runs; apply via Admin → System → Upgrade or
# `php artisan hearth:upgrade`. ASYMMETRY: auto mode is what shields signed-in pages during the window —
# in manual mode they may error on new columns until you apply. Leave it on unless you want manual control.
# HEARTH_AUTO_UPGRADE=true
# Advanced tuning (rarely changed): lock window for one run (s); max unattended attempts before holding for
# the operator; Retry-After hint on the maintenance 503 (s).
# HEARTH_UPGRADE_LOCK_SECONDS=600
# HEARTH_UPGRADE_MAX_ATTEMPTS=2
# HEARTH_UPGRADE_RETRY_AFTER=30

# ════════════════════════════════════════════════════════════════════════════════════════════════════
# ENHANCED TIER (Docker / VPS) — uncomment a block to enable it. No application code changes.
# ════════════════════════════════════════════════════════════════════════════════════════════════════

# ── Redis: shared cache/session + a real queue worker ───────────────────────────────────────────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# Then switch the drivers to redis and run a worker (`php artisan queue:work`) instead of the cron drain:
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis

# ── Meilisearch: instant typo-tolerant search ───────────────────────────────────────────────────────
# SCOUT_DRIVER=meilisearch
# SCOUT_QUEUE=true
# MEILISEARCH_HOST=http://127.0.0.1:7700
# MEILISEARCH_KEY=

# ── S3 / MinIO: object storage for uploads (stateless app, CDN-friendly) ─────────────────────────────
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Reverb: WebSockets for real-time notifications (Phase 4) ─────────────────────────────────────────
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST="localhost"
# REVERB_PORT=8080
# REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
